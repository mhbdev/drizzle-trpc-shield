{
  "name": "drizzle-trpc-shield",
  "version": "0.1.4",
  "description": "A secure, type-safe tRPC API layer generated from Drizzle ORM schemas.",
  "type": "module",
  "license": "MIT",
  "author": "mhbdev",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:declaration": "tsc -p tsconfig.declaration-tests.json",
    "test:type": "tsc -p tsconfig.type-tests.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:type && pnpm test:declaration && pnpm test && pnpm build",
    "publint": "publint",
    "attw": "attw --pack ."
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "trpc",
    "api",
    "authorization",
    "rbac",
    "typescript",
    "zod"
  ],
  "peerDependencies": {
    "@trpc/server": ">=11",
    "drizzle-orm": ">=0.36",
    "zod": ">=3.22 || >=4"
  },
  "dependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "latest",
    "@eslint/js": "latest",
    "@trpc/server": "latest",
    "drizzle-orm": "latest",
    "eslint": "latest",
    "expect-type": "latest",
    "publint": "latest",
    "rimraf": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest",
    "zod": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2"
}
